// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  description String
  date        DateTime
  type        String   @default("expense") // "income" or "expense"
  
  // Daily spending tracker
  isDiscretionary Boolean @default(true)
  isTransfer   Boolean  @default(false)
  isRecurring  Boolean  @default(false)
  recurringId  String?  // For grouping recurring transactions
  
  // For bank statement reconciliation
  statementId  String?  // Identifier from bank statement
  reconciled   Boolean  @default(false)
  
  // Smart deduplication
  isDuplicate  Boolean  @default(false)
  duplicateOfId String? // Points to the original transaction
  fingerprint  String?  // Hash of (amount + normalized description + date)
  source       String?  // "manual", "screenshot", "import", "plaid"
  
  // Account relation
  account      Account? @relation(fields: [accountId], references: [id])
  accountId    String?
  
  // Bill relation
  bill         Bill?    @relation(fields: [billId], references: [id])
  billId       String?

  category    Category? @relation(fields: [categoryId], references: [id])
  categoryId  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String?  // Emoji or Lucide icon name
  color     String?  // Hex code or Tailwind class
  type      String   @default("expense") // "income" or "expense"
  
  // For nested categories
  parentId  String?
  parent    Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToCategory")
  
  // Rules for auto-categorization (stored as JSON string)
  rules     String?   // JSON array of matching rules stored as text
  
  transactions Transaction[]
  budgets      Budget[]
  bills        Bill[]
  goals        Goal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Budget {
  id         String   @id @default(uuid())
  amount     Float
  period     String   // e.g., "2023-10"
  
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([categoryId, period])
}

model Account {
  id          String   @id @default(uuid())
  name        String
  type        String   // checking, savings, credit, investment, cash
  institution String?  // Tangerine, RBC, TD, etc.
  balance     Float    @default(0)
  color       String?  // Hex color for UI
  isDefault   Boolean  @default(false) // Default account for transactions
  
  transactions Transaction[]
  bills        Bill[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bill {
  id          String   @id @default(uuid())
  name        String
  amount      Float
  dueDay      Int      // Day of month (1-31)
  frequency   String   @default("monthly") // monthly, weekly, biweekly
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String
  account     Account  @relation(fields: [accountId], references: [id])
  accountId   String
  isAutoDeduct Boolean @default(false)
  isActive    Boolean  @default(true)
  
  transactions Transaction[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Goal {
  id          String   @id @default(uuid())
  name        String
  targetAmount Float
  currentAmount Float @default(0)
  targetDate  DateTime?
  category    Category? @relation(fields: [categoryId], references: [id])
  categoryId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Multiple income sources
model Income {
  id          String   @id @default(uuid())
  name        String   @default("Primary Income")
  amount      Float
  frequency   String   @default("monthly") // monthly, biweekly, weekly
  startDate   DateTime @db.Date
  dayOfMonth  Int?     // For monthly: day of month (1-31)
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Raw screenshot receipts from camera upload
model ScreenshotReceipt {
  id           String   @id @default(uuid())
  imageUrl     String
  status       String   @default("pending") // pending, processed, rejected
  
  // Parsed data
  rawAmount    Float?   // What the user might edit
  rawMerchant  String?
  rawDate      DateTime?
  rawItems     String?  // JSON array of line items
  confidence   Float?   // AI confidence score 0-1
  
  // Linked on approval
  transactionId String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Smart spending patterns for the algorithm layer
model SpendingPattern {
  id            String   @id @default(uuid())
  categoryId    String
  avgAmount     Float
  frequency     String   // daily, weekly, monthly
  dayOfWeek     Int?     // 0-6 for weekly
  dayOfMonth    Int?     // for monthly
  confidence    Float    @default(0.5)
  lastSeen      DateTime
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Tracks the day's available spending and rollover state per period
model DailyPeriod {
  id              String   @id @default(uuid())
  periodStart     DateTime
  periodEnd       DateTime
  totalIncome     Float
  billsTotal      Float
  dailyAllowance  Float
  accumulatedSurplus Float @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
